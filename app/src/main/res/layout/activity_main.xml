<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <!-- ========== START SCREEN ========== -->
    <LinearLayout
        android:id="@+id/startScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="28dp"
            android:paddingTop="28dp"
            android:paddingEnd="28dp">
            <ImageView
                android:id="@+id/hamburgerStart"
                android:layout_width="40dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_hamburger"
                android:layout_gravity="start|center_vertical"
                android:padding="4dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"/>
        </FrameLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kikoeruca"
            android:textSize="64sp"
            android:textStyle="bold"
            android:textColor="#222222"
            android:letterSpacing="-0.02"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="聴覚情報処理 了解度測定"
            android:textSize="16sp"
            android:textColor="@color/text_gray"
            android:layout_marginTop="8dp"
            android:letterSpacing="0.05"/>

        <View
            android:layout_width="0dp"
            android:layout_height="80dp"/>

        <FrameLayout
            android:id="@+id/btnMeasure"
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:background="@drawable/bg_circle_start"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="測定開始"
                android:textSize="30sp"
                android:textStyle="bold"
                android:textColor="#333333"/>
        </FrameLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="2"/>
    </LinearLayout>

    <!-- ========== MEASURING SCREEN ========== -->
    <LinearLayout
        android:id="@+id/measuringScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:visibility="gone">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="28dp"
            android:paddingTop="28dp"
            android:paddingEnd="28dp">
            <ImageView
                android:id="@+id/hamburgerMeasure"
                android:layout_width="40dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_hamburger"
                android:layout_gravity="start|center_vertical"
                android:padding="4dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"/>
        </FrameLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="計測中..."
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            android:letterSpacing="0.05"
            android:layout_marginBottom="24dp"/>

        <FrameLayout
            android:layout_width="300dp"
            android:layout_height="340dp">

            <com.kikoeruca.debug.RingGaugeView
                android:id="@+id/ringGauge"
                android:layout_width="300dp"
                android:layout_height="300dp"/>

            <TextView
                android:id="@+id/zoneText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="40dp"
                android:textSize="30sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"/>

            <TextView
                android:id="@+id/scoreText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:gravity="center"
                android:text="--"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"/>
        </FrameLayout>

        <LinearLayout
            android:id="@+id/btnStop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginTop="36dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">

            <FrameLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_stop_button"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="停止"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="2"/>
    </LinearLayout>

    <!-- ========== MENU SCREEN ========== -->
    <LinearLayout
        android:id="@+id/menuScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:visibility="gone">

        <!-- Menu header -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="84dp"
            android:layout_marginBottom="20dp">

            <ImageView
                android:id="@+id/hamburgerMenu"
                android:layout_width="40dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_hamburger"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="28dp"
                android:padding="4dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="メニュー"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#222222"/>
        </FrameLayout>

        <!-- Settings -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="32dp">

            <!-- Vibration toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_menu_card"
                android:paddingHorizontal="24dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="バイブレーション"
                    android:textSize="18sp"
                    android:textColor="@color/menu_text"
                    android:fontFamily="sans-serif-medium"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchVibration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:trackTint="@color/switch_track_color"
                    app:thumbTint="@color/switch_thumb_color"/>
            </LinearLayout>

            <!-- Background measurement toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_menu_card"
                android:paddingHorizontal="24dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="バックグラウンド測定"
                    android:textSize="18sp"
                    android:textColor="@color/menu_text"
                    android:fontFamily="sans-serif-medium"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchBackground"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:trackTint="@color/switch_track_color"
                    app:thumbTint="@color/switch_thumb_color"/>
            </LinearLayout>

            <!-- Meter intensity slider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_menu_card"
                android:paddingHorizontal="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="メーター強度"
                    android:textSize="18sp"
                    android:textColor="@color/menu_text"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginEnd="16dp"/>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_slider_track">

                    <SeekBar
                        android:id="@+id/seekMeterIntensity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:max="100"
                        android:progress="50"
                        android:progressTint="#DDDDDD"
                        android:progressBackgroundTint="#DDDDDD"
                        android:thumbTint="#555555"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"/>
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- Logo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingBottom="80dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kikoeruca"
                android:textSize="36sp"
                android:textStyle="bold"
                android:textColor="#333333"/>
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
